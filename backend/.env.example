# Copy this file to .env and adjust values.

# --- Server ---
PORT=3001
SECRET_KEY=change-me-in-production

# Origin of the separate frontend server (for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# --- Admin account (seeded on first run) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Per-venue staff logins (seeded/synced on every boot) ---
# Each account is locked to its venue (see EXTRA_ADMINS in server.js) — they
# can only open/view/submit that venue's form, never another one.
# Defaults: kashish/kashish@2026 (Amravti), veer/veer@2026, irfan/irfan@2026,
# abhishek/abhishek@2026 (Nagpur), vinod/vinod@2026, tushar/tushar@2026
# (Pablo), shabbir/shabbir@2026, tarneem/tarneem@2026, umesh/umesh@2026,
# ravi/ravi@2026 (Navi Mumbai), sandeep/sandeep@2026, narendra/narendra@2026
# (Dali). Override individual passwords here.
# ADMIN_PASSWORD_KASHISH=
# ADMIN_PASSWORD_VEER=
# ADMIN_PASSWORD_IRFAN=
# ADMIN_PASSWORD_ABHISHEK=
# ADMIN_PASSWORD_VINOD=
# ADMIN_PASSWORD_TUSHAR=
# ADMIN_PASSWORD_SHABBIR=
# ADMIN_PASSWORD_TARNEEM=
# ADMIN_PASSWORD_UMESH=
# ADMIN_PASSWORD_RAVI=
# ADMIN_PASSWORD_SANDEEP=
# ADMIN_PASSWORD_NARENDRA=

# --- MongoDB (local) ---
MONGODB_URI=mongodb://127.0.0.1:27017/amravti_fp
MONGODB_DB=amravti_fp

# --- Email (booking PDF sent on submit) ---
# SMTP settings for the cpgh.in mail server. Port 465 => SMTP_SECURE=true,
# port 587 => SMTP_SECURE=false (STARTTLS). Leave blank to disable emailing.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Centre Point Amravti <digital@cpgh.in>
# Comma-separated recipient lists, one per branch. MAIL_RECIPIENTS still works
# as an alias for MAIL_RECIPIENTS_AMRAVTI (backward compatible).
MAIL_RECIPIENTS_AMRAVTI=
# If a branch's var is left blank, its built-in default list is used
# (see backend/mailer.js → BRANCH_CONFIG).
MAIL_RECIPIENTS_NAGPUR=
MAIL_RECIPIENTS_PABLO=
MAIL_RECIPIENTS_NAVIMUMBAI=
MAIL_RECIPIENTS_DALI=
