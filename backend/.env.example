# Copy this file to .env and adjust values.

# --- Server ---
PORT=3001
SECRET_KEY=change-me-in-production

# Origin of the separate frontend server (for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# --- Admin account (seeded on first run) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Centre Point Nagpur staff logins (seeded/upserted on every boot) ---
# Defaults: veer/veer@2026, irfan/irfan@2026, abhishek/abhishek@2026.
# Override individual passwords here if needed.
# ADMIN_PASSWORD_VEER=
# ADMIN_PASSWORD_IRFAN=
# ADMIN_PASSWORD_ABHISHEK=

# --- MongoDB (local) ---
MONGODB_URI=mongodb://127.0.0.1:27017/amravti_fp
MONGODB_DB=amravti_fp

# --- Email (booking PDF sent on submit) ---
# SMTP settings for the cpgh.in mail server. Port 465 => SMTP_SECURE=true,
# port 587 => SMTP_SECURE=false (STARTTLS). Leave blank to disable emailing.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Centre Point Amravti <digital@cpgh.in>
# Comma-separated recipient lists, one per branch. MAIL_RECIPIENTS still works
# as an alias for MAIL_RECIPIENTS_AMRAVTI (backward compatible).
MAIL_RECIPIENTS_AMRAVTI=
# If MAIL_RECIPIENTS_NAGPUR is left blank, a built-in default list is used
# (see backend/mailer.js → DEFAULT_NAGPUR_RECIPIENTS).
MAIL_RECIPIENTS_NAGPUR=
