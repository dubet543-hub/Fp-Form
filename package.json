{
  "name": "amravti-fp",
  "version": "1.0.0",
  "description": "Centre Point Amravti function booking app (Express + MongoDB/Mongoose)",
  "type": "commonjs",
  "main": "backend/server.js",
  "scripts": {
    "free-ports": "node free-ports.js",
    "prestart": "node free-ports.js",
    "predev": "node free-ports.js",
    "start": "concurrently -n backend,frontend -c blue,green \"npm:start:backend\" \"npm:start:frontend\"",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "start:backend": "node backend/server.js",
    "start:frontend": "node frontend/server.js",
    "dev:backend": "node --watch backend/server.js",
    "dev:frontend": "node --watch frontend/server.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "mongoose": "^9.7.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
